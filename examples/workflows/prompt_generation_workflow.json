{
  "version": 2,
  "kind": "workflow",
  "name": "prompt_generation_workflow",
  "entrypoint": "scene_document_editor",
  "ui": {
    "title": "图像提示词工程",
    "description": "持续编辑结构化画面，并编译为目标生图模型可用的 Prompt",
    "input_placeholder": "描述画面，或继续修改人物、动作、关系、场景与构图……",
    "input_hint": "支持多轮修改；未指定时使用 NAI V4",
    "controls": [
      {
        "key": "prompt_strategy",
        "label": "提示策略",
        "type": "segmented",
        "default": "expressive",
        "options": [
          { "value": "expressive", "label": "积极扩写" },
          { "value": "faithful", "label": "保守还原" }
        ]
      },
      {
        "key": "target_model",
        "label": "目标模型",
        "type": "select",
        "default": "nai_v4",
        "options": [
          { "value": "nai_v4", "label": "NAI V4（混合提示）" },
          { "value": "nai_v3", "label": "NAI V3（标签优先）" },
          { "value": "sdxl", "label": "SDXL" },
          { "value": "illustrious", "label": "Illustrious / 光辉" },
          { "value": "pony", "label": "Pony" },
          { "value": "flux", "label": "Flux" },
          { "value": "auto", "label": "从需求识别" }
        ]
      }
    ]
  },
  "nodes": {
    "scene_document_editor": {
      "agent": "scene_document_editor",
      "display_name": "理解本轮修改",
      "agent_package": "prompt_generation/scene_document_editor",
      "extension": "pipeline_context"
    },
    "scene_document_processor": {
      "agent": "scene_document_processor",
      "display_name": "更新画面工程",
      "agent_package": "prompt_generation/scene_document_processor",
      "extension": "pipeline_context"
    },
    "character_identity_resolver": {
      "agent": "character_identity_resolver",
      "display_name": "解析角色身份",
      "agent_package": "prompt_generation/character_identity_resolver",
      "extension": "pipeline_context"
    },
    "visual_semantic_resolver": {
      "agent": "visual_semantic_resolver",
      "display_name": "解析视觉语义",
      "agent_package": "prompt_generation/visual_semantic_resolver",
      "extension": "pipeline_context"
    },
    "prompt_compiler": {
      "agent": "prompt_compiler",
      "display_name": "编译 Prompt IR",
      "agent_package": "prompt_generation/prompt_compiler",
      "extension": "pipeline_context"
    },
    "consistency_validator": {
      "agent": "prompt_consistency_validator",
      "display_name": "检查一致性",
      "agent_package": "prompt_generation/prompt_consistency_validator",
      "extension": "pipeline_context"
    },
    "semantic_repairer": {
      "agent": "prompt_semantic_repairer",
      "display_name": "定向修复",
      "agent_package": "prompt_generation/prompt_semantic_repairer",
      "extension": "pipeline_context"
    },
    "target_renderer": {
      "agent": "prompt_target_renderer",
      "display_name": "渲染目标格式",
      "agent_package": "prompt_generation/prompt_target_renderer",
      "extension": "pipeline_context"
    }
  },
  "edges": [
    { "from": "scene_document_editor", "to": "scene_document_processor" },
    {
      "from": "scene_document_processor",
      "to": ["character_identity_resolver", "visual_semantic_resolver"]
    },
    {
      "from": ["character_identity_resolver", "visual_semantic_resolver"],
      "to": "prompt_compiler"
    },
    { "from": "prompt_compiler", "to": "consistency_validator" },
    {
      "from": "consistency_validator",
      "to": "semantic_repairer",
      "otherwise": "target_renderer",
      "condition": {
        "path": "nodes.consistency_validator.needs_repair",
        "operator": "equals",
        "value": true
      },
      "loop": {
        "counter_path": "nodes.semantic_repairer.repair_attempts",
        "max_iterations": 1,
        "exhausted": "target_renderer"
      }
    },
    { "from": "semantic_repairer", "to": "prompt_compiler" },
    { "from": "target_renderer", "to": "END" }
  ]
}
