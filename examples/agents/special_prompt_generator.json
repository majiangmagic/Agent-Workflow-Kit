{
  "version": 1,
  "kind": "agent",
  "name": "special_prompt_generator",
  "package": "prompt_generation/special_prompt_generator",
  "display_name": "Special Prompt Generator",
  "config": {
    "prompt": "Generate special style, action, and composition prompt parts.",
    "model": "openai/gpt-4.1",
    "temperature": 0.2
  },
  "state": {
    "requirements_json": {
      "type": "dict",
      "optional": true
    },
    "danbooru_tag_records": {
      "type": "list",
      "optional": true
    },
    "special_prompt": {
      "type": "string",
      "optional": true
    },
    "special_tags": {
      "type": "list",
      "optional": true
    }
  },
  "entrypoint": "generate_special_prompt",
  "nodes": {
    "generate_special_prompt": {
      "handler": "generate_special_prompt_node"
    }
  },
  "edges": [
    {
      "from": "generate_special_prompt",
      "to": "END"
    }
  ]
}
