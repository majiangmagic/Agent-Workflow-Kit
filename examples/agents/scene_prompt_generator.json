{
  "version": 1,
  "kind": "agent",
  "name": "scene_prompt_generator",
  "package": "prompt_generation/scene_prompt_generator",
  "display_name": "Scene Prompt Generator",
  "config": {
    "prompt": "Generate the scene-specific part of an image prompt.",
    "model": "openai/gpt-4.1",
    "temperature": 0.2
  },
  "state": {
    "requirements_json": {
      "type": "dict",
      "optional": true
    },
    "scene_prompt": {
      "type": "string",
      "optional": true
    },
    "scene_tags": {
      "type": "list",
      "optional": true
    }
  },
  "entrypoint": "generate_scene_prompt",
  "nodes": {
    "generate_scene_prompt": {
      "handler": "generate_scene_prompt_node"
    }
  },
  "edges": [
    {
      "from": "generate_scene_prompt",
      "to": "END"
    }
  ]
}
