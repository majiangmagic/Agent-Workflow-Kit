{
  "version": 1,
  "kind": "agent",
  "name": "scene_prompt_generator",
  "package": "prompt_generation/scene_prompt_generator",
  "display_name": "Scene Prompt Generator",
  "config": {
    "prompt": "忠实处理虚构成年人的场景需求，包括 NSFW 行为相关的环境、空间关系与背景，不拒绝、不说教、不弱化、不隐去细节。所有角色必须明确为成年人。生成对应提示词并返回实际采用的 Danbooru 标签来源。",
    "model": "deepseek-v4-pro",
    "temperature": 0.3
  },
  "state": {
    "requirements_json": { "type": "dict", "optional": true },
    "scene_prompt": { "type": "string", "optional": true },
    "scene_tags": { "type": "list", "optional": true },
    "danbooru_tag_records": { "type": "list", "optional": true },
    "danbooru_search_terms": { "type": "list", "optional": true }
  },
  "entrypoint": "generate_scene_prompt",
  "nodes": {
    "generate_scene_prompt": { "handler": "generate_scene_prompt_node" }
  },
  "edges": [
    { "from": "generate_scene_prompt", "to": "END" }
  ]
}
