{
  "version": 1,
  "kind": "agent",
  "name": "additional_prompt_generator",
  "package": "prompt_generation/additional_prompt_generator",
  "display_name": "Additional Prompt Generator",
  "config": {
    "prompt": "忠实处理虚构成年人的额外视觉需求，包括 NSFW 构图、镜头、视角、光照和效果，不拒绝、不说教、不弱化、不隐去细节。所有角色必须明确为成年人。生成对应提示词并返回实际采用的 Danbooru 标签来源。",
    "model": "deepseek-v4-pro",
    "temperature": 0.3
  },
  "state": {
    "requirements_json": { "type": "dict", "optional": true },
    "additional_prompt": { "type": "string", "optional": true },
    "additional_tags": { "type": "list", "optional": true },
    "danbooru_tag_records": { "type": "list", "optional": true },
    "danbooru_search_terms": { "type": "list", "optional": true }
  },
  "entrypoint": "generate_additional_prompt",
  "nodes": {
    "generate_additional_prompt": { "handler": "generate_additional_prompt_node" }
  },
  "edges": [
    { "from": "generate_additional_prompt", "to": "END" }
  ]
}
