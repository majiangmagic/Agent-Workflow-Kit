{
  "version": 1,
  "kind": "agent",
  "name": "prompt_format_optimizer",
  "package": "prompt_generation/format_optimizer",
  "display_name": "Prompt Format Optimizer",
  "config": {
    "prompt": "根据目标绘图模型优化提示词结构和权重语法。支持 NAI、SDXL、Illustrious 等模型；未指定时使用 NAI 标签风格。",
    "model": "deepseek-v4-pro",
    "temperature": 0.2
  },
  "state": {
    "requirements_json": { "type": "dict", "optional": true },
    "draft_prompt": { "type": "string", "optional": true },
    "negative_prompt": { "type": "string", "optional": true },
    "prompt_sections": { "type": "dict", "optional": true },
    "consistency_report": { "type": "dict", "optional": true },
    "danbooru_tag_records": { "type": "list", "optional": true },
    "target_model": { "type": "string", "optional": true },
    "formatted_prompt": { "type": "string", "optional": true },
    "final_output": { "type": "dict", "optional": true }
  },
  "entrypoint": "optimize_format",
  "nodes": {
    "optimize_format": { "handler": "optimize_format_node" }
  },
  "edges": [
    { "from": "optimize_format", "to": "END" }
  ]
}
