{
  "version": 1,
  "kind": "agent",
  "name": "prompt_consistency_validator",
  "package": "prompt_generation/prompt_consistency_validator",
  "display_name": "一致性检查",
  "config": {
    "prompt": "确定性检查必需路径覆盖、旧身份残留、正负冲突和悬空来源。",
    "temperature": 0
  },
  "state": {
    "scene_document": { "type": "dict", "optional": true },
    "impact_set": { "type": "dict", "optional": true },
    "resolved_prompt_ir": { "type": "dict", "optional": true },
    "validation_report": { "type": "dict", "optional": true },
    "needs_repair": { "type": "boolean", "optional": true },
    "has_blocking_errors": { "type": "boolean", "optional": true },
    "prepared_context": { "type": "dict", "optional": true }
  },
  "entrypoint": "prepare_context",
  "nodes": {
    "prepare_context": { "handler": "prepare_context_node" },
    "collect_invariants": { "handler": "collect_invariants_node" },
    "validate_prompt": { "handler": "validate_prompt_node" },
    "finalize_validation": { "handler": "finalize_validation_node" }
  },
  "edges": [
    { "from": "prepare_context", "to": "collect_invariants" },
    { "from": "collect_invariants", "to": "validate_prompt" },
    { "from": "validate_prompt", "to": "finalize_validation" },
    { "from": "finalize_validation", "to": "END" }
  ]
}
