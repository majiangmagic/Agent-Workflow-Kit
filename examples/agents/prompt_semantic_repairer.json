{
  "version": 1,
  "kind": "agent",
  "name": "prompt_semantic_repairer",
  "package": "prompt_generation/prompt_semantic_repairer",
  "display_name": "定向语义修复",
  "config": {
    "prompt": "只根据 ValidationReport 修复已指出的 PromptIR 缺失、残留或极性错误，不重写 SceneDocument，不添加新的角色、动作或构图。",
    "model": "deepseek-v4-pro",
    "temperature": 0.1
  },
  "state": {
    "scene_document": { "type": "dict", "optional": true },
    "resolved_prompt_ir": { "type": "dict", "optional": true },
    "validation_report": { "type": "dict", "optional": true },
    "repair_overlay": { "type": "dict", "optional": true },
    "repair_attempts": { "type": "integer", "optional": true },
    "prepared_context": { "type": "dict", "optional": true }
  },
  "entrypoint": "prepare_context",
  "nodes": {
    "prepare_context": { "handler": "prepare_context_node" },
    "collect_repair_scope": { "handler": "collect_repair_scope_node" },
    "repair_semantics": { "handler": "repair_semantics_node" },
    "validate_repair": { "handler": "validate_repair_node" }
  },
  "edges": [
    { "from": "prepare_context", "to": "collect_repair_scope" },
    { "from": "collect_repair_scope", "to": "repair_semantics" },
    { "from": "repair_semantics", "to": "validate_repair" },
    { "from": "validate_repair", "to": "END" }
  ]
}
