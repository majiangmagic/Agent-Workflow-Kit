{
  "version": 1,
  "kind": "agent",
  "name": "prompt_compiler",
  "package": "prompt_generation/prompt_compiler",
  "display_name": "Prompt 编译",
  "config": {
    "prompt": "确定性汇总带来源的身份标签、原子标签、关系短语与负向约束，应用修复覆盖并生成 ResolvedPromptIR。",
    "temperature": 0
  },
  "state": {
    "scene_document": { "type": "dict", "optional": true },
    "previous_resolved_prompt_ir": { "type": "dict", "optional": true },
    "impact_set": { "type": "dict", "optional": true },
    "identity_terms": { "type": "list", "optional": true },
    "atomic_terms": { "type": "list", "optional": true },
    "relation_terms": { "type": "list", "optional": true },
    "negative_terms": { "type": "list", "optional": true },
    "identity_tag_records": { "type": "list", "optional": true },
    "identity_tag_resolutions": { "type": "list", "optional": true },
    "identity_tag_adjudication": { "type": "dict", "optional": true },
    "visual_tag_records": { "type": "list", "optional": true },
    "visual_tag_resolutions": { "type": "list", "optional": true },
    "visual_tag_adjudication": { "type": "dict", "optional": true },
    "repair_overlay": { "type": "dict", "optional": true },
    "resolved_prompt_ir": { "type": "dict", "optional": true },
    "draft_prompt": { "type": "string", "optional": true },
    "negative_prompt": { "type": "string", "optional": true },
    "prepared_context": { "type": "dict", "optional": true }
  },
  "entrypoint": "prepare_context",
  "nodes": {
    "prepare_context": { "handler": "prepare_context_node" },
    "collect_terms": { "handler": "collect_terms_node" },
    "compile_prompt": { "handler": "compile_prompt_node" },
    "validate_prompt_ir": { "handler": "validate_prompt_ir_node" }
  },
  "edges": [
    { "from": "prepare_context", "to": "collect_terms" },
    { "from": "collect_terms", "to": "compile_prompt" },
    { "from": "compile_prompt", "to": "validate_prompt_ir" },
    { "from": "validate_prompt_ir", "to": "END" }
  ]
}
