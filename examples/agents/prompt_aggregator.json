{
  "version": 1,
  "kind": "agent",
  "name": "prompt_aggregator",
  "package": "prompt_generation/prompt_aggregator",
  "display_name": "Prompt Aggregator",
  "config": {
    "prompt": "汇总人物、场景和额外提示词，消除冲突与重复，保留可追溯的 Danbooru 标签来源。",
    "model": "deepseek-v4-pro",
    "temperature": 0.2
  },
  "state": {
    "requirements_json": { "type": "dict", "optional": true },
    "character_prompt": { "type": "string", "optional": true },
    "character_tags": { "type": "list", "optional": true },
    "scene_prompt": { "type": "string", "optional": true },
    "scene_tags": { "type": "list", "optional": true },
    "additional_prompt": { "type": "string", "optional": true },
    "additional_tags": { "type": "list", "optional": true },
    "danbooru_tag_records": { "type": "list", "optional": true },
    "danbooru_search_terms": { "type": "list", "optional": true },
    "draft_prompt": { "type": "string", "optional": true },
    "negative_prompt": { "type": "string", "optional": true },
    "prompt_sections": { "type": "dict", "optional": true },
    "consistency_report": { "type": "dict", "optional": true }
  },
  "entrypoint": "aggregate_prompt",
  "nodes": {
    "aggregate_prompt": { "handler": "aggregate_prompt_node" }
  },
  "edges": [
    { "from": "aggregate_prompt", "to": "END" }
  ]
}
